# Variaveis de ambiente da suite E2E (tests/e2e).
# ESTE ARQUIVO E' UM MODELO: NAO coloque valores reais aqui nem commite segredos.
#
# Como usar:
#   1. Copie para .env.e2e.local (gitignored) e preencha os valores, OU
#   2. Exporte as variaveis no seu shell antes de rodar `npm run test:e2e`.
#   (A config playwright.e2e.config.ts carrega .env.e2e.local automaticamente, sem libs.)
#
# IMPORTANTE: os testes rodam contra STAGING (Next dev local + DB de staging).
# O guard anti-producao SO permite localhost/127.0.0.1. NUNCA aponte para producao.

# Alvo dos testes (Next dev local).
PLAYWRIGHT_BASE_URL=http://localhost:3000

# (Opcional) Estende a allowlist de hosts do guard anti-producao (lista por virgula).
# Por padrao so localhost/127.0.0.1/::1 sao permitidos.
# E2E_ALLOWED_HOSTS=

# Super admin existente (fluxos de escrita/aprovacao).
E2E_ADMIN_USERNAME=
E2E_ADMIN_PASSWORD=

# Usuario NAO-super com acesso as 2 unidades (permissoes compras/RH view+manage).
E2E_MULTI_USERNAME=
E2E_MULTI_PASSWORD=
